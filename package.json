{
  "name": "the-unbound",
  "private": true,
  "version": "0.6.0",
  "description": "The Unbound — A minimalist retro fantasy roguelike of exploration and resource management.",
  "license": "MIT",
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit && node scripts/build-cart.mjs",
    "dev": "node scripts/dev.mjs",
    "play": "node scripts/run-terminal.mjs",
    "test": "vitest run",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "verify": "npm run build && npm run typecheck:test && npm run test"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "tic80-typescript": "^2.2.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.5"
  }
}
